{
    "name": "santwer/bearschedule",
    "type": "project",
    "description": "Simple and clear project management tool. With which it is possible to display one or more projects graphically. ",
    "keywords": [
        "framework",
        "laravel",
        "vuejs",
        "project management",
        "project",
        "management",
        "tool",
        "graphical",
        "timeline",
        "schedule",
        "gantt",
        "gantt chart",
        "planning",
        "planner"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.10",
        "kg-bot/laravel-localization-to-vue": "^2.4",
        "laravel/ai": "^0.7.2",
        "laravel/framework": "^13.0",
        "laravel/mcp": "^0.7.2",
        "laravel/pulse": "^1.7",
        "laravel/tinker": "^3.0",
        "laravel/ui": "^4.6",
        "league/oauth2-client": "^2.9",
        "lesstif/php-jira-rest-client": "^5.12",
        "maatwebsite/excel": "^3.1.69",
        "microsoft/microsoft-graph": "^1.110",
        "pusher/pusher-php-server": "^7.2",
        "ryangjchandler/laravel-cloudflare-turnstile": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.4",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^12.0"
    },
    "config": {
        "platform": {
            "php": "8.4.0"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
